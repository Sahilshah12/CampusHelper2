<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:clipToPadding="false">

    <!-- AI Message -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/aiMessageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="60dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E0E0E0">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvAiMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI message content"
                android:textSize="15sp"
                android:textColor="@android:color/black"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:id="@+id/tvAiTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30"
                android:textSize="11sp"
                android:textColor="@android:color/black"
                android:alpha="0.6"
                android:layout_marginTop="4dp"
                android:layout_gravity="start"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- User Message -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/userMessageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="60dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="?attr/colorPrimary">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvUserMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User message content"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:id="@+id/tvUserTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:alpha="0.7"
                android:layout_marginTop="4dp"
                android:layout_gravity="end"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
